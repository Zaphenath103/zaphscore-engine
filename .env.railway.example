# ZSE Railway Environment Variables
# Copy these into Railway dashboard → Variables tab
# DO NOT commit this file with real values

# ── Database (Railway provides this automatically when you add PostgreSQL plugin) ──
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
# OR use Supabase:
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY

# ── GitHub (for scanning repos) ──
# Option A: Personal Access Token (easy, 5000 req/hr)
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# Option B: GitHub App (higher rate limits — advanced)
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=

# ── Scan settings ──
SCAN_CONCURRENCY=3
MAX_REPO_SIZE_MB=500
CLONE_TIMEOUT_SECONDS=120

# ── Server ──
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=https://zaphenath.app,https://zaphscore.zaphenath.app
